using Gtk 4.0;

template $LanguageRow : Box {
  Box {
    margin-bottom: 6;
    margin-end: 8;
    margin-start: 8;
    margin-top: 6;

    Label label {
      hexpand: true;
      halign: start;

      styles [
        "title",
      ]
    }

    Button install_btn {
      icon-name: "folder-download-symbolic";
      tooltip-text: C_("Preferences Language Row", "Install language");
      clicked => $on_download() swapped;

      styles ["flat"]
    }

    Button remove_btn {
      visible: bind install_btn.visible inverted bidirectional;
      icon-name: "user-trash-symbolic";
      tooltip-text: C_("Preferences Language Row", "Remove language");
      clicked => $on_remove() swapped;

      styles ["flat"]
    }
  }

  [overlay]
  Revealer revealer {
    valign: end;

    ProgressBar progress_bar {
      valign: end;
      fraction: 0.14;

      styles [
        "osd",
      ]
    }
  }
}
